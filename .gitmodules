[submodule "duckdb"]
	path = duckdb
	# Stock mainline DuckDB (public, HTTPS) — pinned to a v1.5.1 commit. This
	# extension builds against unmodified DuckDB; it no longer needs the
	# cwida/duckdb-pgq fork.
	url = https://github.com/duckdb/duckdb.git

[submodule "extension-ci-tools"]
	path = extension-ci-tools
	url = git@github.com:duckdb/extension-ci-tools.git
