# name: test/sql/scalar/common_neighbors.test
# description: Testing the pairwise common neighbors implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (
    Student
    )
EDGE TABLES (
    know    SOURCE KEY ( src ) REFERENCES Student ( id )
            DESTINATION KEY ( dst ) REFERENCES Student ( id )
    );

# Undirected adjacency: 0:{1,2,3} 1:{0,2,3} 2:{0,1,3} 3:{0,1,2,4} 4:{3}
# common_neighbors(a,b) = |N(a) intersect N(b)|, emitted for a<b.
query III
select node1, node2, common_neighbors from common_neighbors(pg, student, know) order by node1, node2;
----
0	1	2
0	2	2
0	3	2
0	4	1
1	2	2
1	3	2
1	4	1
2	3	2
2	4	1
3	4	0
