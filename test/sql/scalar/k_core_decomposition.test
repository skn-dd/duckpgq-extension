# name: test/sql/scalar/k_core_decomposition.test
# description: Testing the k-core decomposition (per-vertex core number) implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

query II
select id, core from k_core_decomposition('Student', 'id', 'know', 'src', 'dst') order by id;
----
0	3
1	3
2	3
3	3
4	1
