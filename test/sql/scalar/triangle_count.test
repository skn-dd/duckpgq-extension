# name: test/sql/scalar/triangle_count.test
# description: Testing the triangle count implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (
    Student
    )
EDGE TABLES (
    know    SOURCE KEY ( src ) REFERENCES Student ( id )
            DESTINATION KEY ( dst ) REFERENCES Student ( id )
    );

# Per-vertex triangle count over the undirected CSR. The reverse-duplicate
# edge (0,3)/(3,0) is deduped to one undirected edge, giving the edge set
# {0-1,0-2,0-3,1-2,1-3,2-3,3-4}. The triangles (3-cliques) are
# {0,1,2}, {0,1,3}, {0,2,3}, {1,2,3}; vertex 4 only connects to 3 so it
# participates in no triangle. Each of vertices 0-3 is in exactly 3 of the
# 4 triangles.
query II
select id, triangle_count from triangle_count(pg, student, know) order by id;
----
0	3
1	3
2	3
3	3
4	0
