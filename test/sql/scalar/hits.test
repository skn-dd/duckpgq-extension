# name: test/sql/scalar/hits.test
# description: Testing the HITS (hub & authority) implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'Daniel'), (1, 'Tavneet'), (2, 'Gabor'), (3, 'Peter'), (4, 'David');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

# Authority ranking: vertex 3 has in-edges from 0,1,2,4 (top authority);
# vertex 2 from 0,1; vertex 1 from 0; vertex 0 only from 3 (whose hub -> 0);
# vertex 4 has no in-edges (authority ~0).
query I
select id from hits_authority('Student', 'id', 'know', 'src', 'dst') order by round(hits_authority, 9) desc, id;
----
3
2
1
0
4

# Hub ranking: vertex 0 points to 1,2,3 (top hub); vertex 1 -> 2,3;
# vertex 2 -> 3; vertex 4 -> 3; vertex 3 -> 0 (whose authority -> 0, hub ~0).
query I
select id from hits_hub('Student', 'id', 'know', 'src', 'dst') order by round(hits_hub, 9) desc, id;
----
0
1
2
4
3

query I
select count(*) from hits_authority('Student', 'id', 'know', 'src', 'dst');
----
5

query I
select count(*) from hits_hub('Student', 'id', 'know', 'src', 'dst');
----
5
