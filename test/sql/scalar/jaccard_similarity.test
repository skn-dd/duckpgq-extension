# name: test/sql/scalar/jaccard_similarity.test
# description: Testing the pairwise jaccard similarity implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

# Undirected adjacency: 0:{1,2,3} 1:{0,2,3} 2:{0,1,3} 3:{0,1,2,4} 4:{3}
# jaccard(a,b) = |N(a) intersect N(b)| / |N(a) union N(b)|, emitted for a<b.
query IIR
select node1, node2, round(jaccard_similarity,4) from jaccard_similarity('Student', 'id', 'know', 'src', 'dst') order by node1, node2;
----
0	1	0.5
0	2	0.5
0	3	0.4
0	4	0.3333
1	2	0.5
1	3	0.4
1	4	0.3333
2	3	0.4
2	4	0.3333
3	4	0.0
