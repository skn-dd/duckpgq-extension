# name: test/sql/scalar/preferential_attachment.test
# description: Testing the pairwise preferential attachment implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

# Undirected adjacency: 0:{1,2,3} 1:{0,2,3} 2:{0,1,3} 3:{0,1,2,4} 4:{3}
# Degrees: 0=3 1=3 2=3 3=4 4=1
# preferential_attachment(a,b) = deg(a) * deg(b), emitted for a<b.
query III
select node1, node2, preferential_attachment from preferential_attachment('Student', 'id', 'know', 'src', 'dst') order by node1, node2;
----
0	1	9
0	2	9
0	3	12
0	4	3
1	2	9
1	3	12
1	4	3
2	3	12
2	4	3
3	4	4
