# name: test/sql/scalar/graph_match.test
# description: Testing decoupled graph_match pattern rewrite on stock DuckDB (edge/vertex tables, no property graph)
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);
INSERT INTO Student VALUES (0, 'Daniel'), (1, 'Tavneet'), (2, 'Gabor'), (3, 'Peter'), (4, 'David');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);
INSERT INTO know VALUES (0,1,10), (0,2,11), (0,3,12), (3,0,13), (1,2,14), (1,3,15), (2,3,16), (4,3,17);

# Fixed-length single hop: (a:Student)-[e:know]->(b:Student).
# graph_match exposes one column per bound relation key: a_id, b_id, e_src, e_dst.
query II
SELECT a_id, b_id
FROM graph_match('(a:Student)-[e:know]->(b:Student)', 'Student', 'id', 'know', 'src', 'dst')
ORDER BY a_id, b_id;
----
0	1
0	2
0	3
1	2
1	3
2	3
3	0
4	3

# The bound edge endpoints match the vertex ids.
query IIII
SELECT a_id, e_src, e_dst, b_id
FROM graph_match('(a:Student)-[e:know]->(b:Student)', 'Student', 'id', 'know', 'src', 'dst')
ORDER BY a_id, b_id;
----
0	0	1	1
0	0	2	2
0	0	3	3
1	1	2	2
1	1	3	3
2	2	3	3
3	3	0	0
4	4	3	3

# Fixed-length two hop: (a)-[e1]->(b)-[e2]->(c).
query III
SELECT a_id, b_id, c_id
FROM graph_match('(a:Student)-[e1:know]->(b:Student)-[e2:know]->(c:Student)', 'Student', 'id', 'know', 'src', 'dst')
ORDER BY a_id, b_id, c_id;
----
0	1	2
0	1	3
0	2	3
0	3	0
1	2	3
1	3	0
2	3	0
3	0	1
3	0	2
3	0	3
4	3	0

# Left-directed edge (a)<-[e]-(b) is the reverse of the right edge.
query II
SELECT a_id, b_id
FROM graph_match('(a:Student)<-[e:know]-(b:Student)', 'Student', 'id', 'know', 'src', 'dst')
ORDER BY a_id, b_id;
----
0	3
1	0
2	0
2	1
3	0
3	1
3	2
3	4

# Variable-length bounded right edge ->{1,2}: reachable within 1..2 hops.
# Only the vertex bindings (a, b) are projected for a variable-length edge.
query II
SELECT DISTINCT a_id, b_id
FROM graph_match('(a:Student)-[e:know]->{1,2}(b:Student)', 'Student', 'id', 'know', 'src', 'dst')
ORDER BY a_id, b_id;
----
0	0
0	1
0	2
0	3
1	0
1	2
1	3
2	0
2	3
3	0
3	1
3	2
3	3
4	0
4	3

# Bad pattern: vertex missing a label.
statement error
SELECT * FROM graph_match('(a)-[e:know]->(b)', 'Student', 'id', 'know', 'src', 'dst');
----
missing a label

# Bad pattern: garbage syntax.
statement error
SELECT * FROM graph_match('(a:Student)=>(b:Student)', 'Student', 'id', 'know', 'src', 'dst');
----
invalid pattern
