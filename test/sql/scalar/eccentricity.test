# name: test/sql/scalar/eccentricity.test
# description: Testing the eccentricity implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

query II
select id, eccentricity from eccentricity('Student', 'id', 'know', 'src', 'dst') order by id;
----
0	2
1	2
2	2
3	1
4	2
