# name: test/sql/scalar/topological_sort.test
# description: Testing the topological sort implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Task(id BIGINT, name VARCHAR);INSERT INTO Task VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE dep(src BIGINT, dst BIGINT, w BIGINT);INSERT INTO dep VALUES (0,1,1), (0,2,1), (1,3,1), (2,3,1), (3,4,1);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (
    Task
    )
EDGE TABLES (
    dep     SOURCE KEY ( src ) REFERENCES Task ( id )
            DESTINATION KEY ( dst ) REFERENCES Task ( id )
    );

query II
select id, topological_order from topological_sort(pg, task, dep) order by id;
----
0	0
1	1
2	2
3	3
4	4
