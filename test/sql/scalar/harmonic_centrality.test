# name: test/sql/scalar/harmonic_centrality.test
# description: Testing the harmonic centrality implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

query II
select id, round(harmonic_centrality, 4) from harmonic_centrality('Student', 'id', 'know', 'src', 'dst') order by id;
----
0	3.5
1	3.5
2	3.5
3	4.0
4	2.5
