INSERT INTO know VALUES (0, 1, 10), (1, 2, 11), (2, 3, 12), (3, 4, 13),
                       (5, 6, 14), (6, 7, 15), (7, 8, 16), (8, 9, 17),
                       (0, 4, 18), (5, 9, 19);

query I
select count(distinct componentId) as c from weakly_connected_component('Student', 'id', 'know', 'src', 'dst') order by c;
----
2

statement ok
CREATE or replace TABLE edges (
    source INTEGER,
    target INTEGER
);

statement ok
INSERT INTO edges VALUES (1, 2), (2, 3), (4, 5), (2, 4), (10,11);

statement ok
CREATE OR REPLACE TABLE nodes AS
   (SELECT DISTINCT id FROM
    (SELECT DISTINCT source AS id FROM edges
    UNION
    SELECT DISTINCT target AS id FROM edges
    ) );

query I
SELECT count(distinct componentId) FROM weakly_connected_component('nodes', 'id', 'edges', 'source', 'target');
----
2
