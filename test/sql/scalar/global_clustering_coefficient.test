# name: test/sql/scalar/global_clustering_coefficient.test
# description: Testing the global clustering coefficient (graph transitivity) implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

# Global clustering coefficient (transitivity) is a single graph-level number,
# returned identically for every vertex. The reverse-duplicate edge (0,3)/(3,0)
# is deduped to one undirected edge, giving the edge set
# {0-1,0-2,0-3,1-2,1-3,2-3,3-4}. This is K4 on {0,1,2,3} plus a pendant 3-4.
# Triangles (3-cliques) = C(4,3) = 4. Degrees: 0:3, 1:3, 2:3, 3:4, 4:1.
# Paths of length 2 = sum C(deg,2) = 3+3+3+6+0 = 15.
# transitivity = (3 * triangles) / paths_of_length_2 = (3*4)/15 = 12/15 = 0.8.
query II
select id, round(global_clustering_coefficient, 4) from global_clustering_coefficient('Student', 'id', 'know', 'src', 'dst') order by id;
----
0	0.8
1	0.8
2	0.8
3	0.8
4	0.8
