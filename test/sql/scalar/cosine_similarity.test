# name: test/sql/scalar/cosine_similarity.test
# description: Testing the pairwise cosine similarity implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

# Undirected adjacency: 0:{1,2,3} 1:{0,2,3} 2:{0,1,3} 3:{0,1,2,4} 4:{3}
# cosine(a,b) = |N(a) intersect N(b)| / (sqrt(|N(a)|) * sqrt(|N(b)|)), emitted for a<b.
query IIR
select node1, node2, round(cosine_similarity,4) from cosine_similarity('Student', 'id', 'know', 'src', 'dst') order by node1, node2;
----
0	1	0.6667
0	2	0.6667
0	3	0.5774
0	4	0.5774
1	2	0.6667
1	3	0.5774
1	4	0.5774
2	3	0.5774
2	4	0.5774
3	4	0.0
