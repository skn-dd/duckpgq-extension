# name: test/sql/scalar/eigenvector_centrality.test
# description: Testing the eigenvector centrality implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (
    Student
    )
EDGE TABLES (
    know    SOURCE KEY ( src ) REFERENCES Student ( id )
            DESTINATION KEY ( dst ) REFERENCES Student ( id )
    );

# Undirected adjacency: 0={1,2,3}, 1={0,2,3}, 2={0,1,3}, 3={0,1,2,4}, 4={3}
# Vertex 3 connects to all -> highest; 0,1,2 are symmetric (equal); 4 -> lowest.
query I
select id from eigenvector_centrality(pg, student, know) order by round(eigenvector_centrality, 9) desc, id;
----
3
0
1
2
4

# Vertices 0, 1, 2 are structurally symmetric -> equal centrality
query I
select count(distinct round(eigenvector_centrality, 6)) from eigenvector_centrality(pg, student, know) where id in (0, 1, 2);
----
1

# Highest is vertex 3, lowest is vertex 4
query I
select id from eigenvector_centrality(pg, student, know) order by eigenvector_centrality desc limit 1;
----
3

query I
select id from eigenvector_centrality(pg, student, know) order by eigenvector_centrality asc limit 1;
----
4
