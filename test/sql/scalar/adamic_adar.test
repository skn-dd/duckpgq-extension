# name: test/sql/scalar/adamic_adar.test
# description: Testing the pairwise adamic adar index implementation
# group: [scalar]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);INSERT INTO Student VALUES (0, 'a'), (1, 'b'), (2, 'c'), (3, 'd'), (4, 'e');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, createDate BIGINT);INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17);

# Undirected adjacency: 0:{1,2,3} 1:{0,2,3} 2:{0,1,3} 3:{0,1,2,4} 4:{3}
# degrees: 0:3 1:3 2:3 3:4 4:1 ; 1/ln(3)=0.9102 1/ln(4)=0.7213
# adamic_adar(a,b) = sum over w in N(a) intersect N(b) of 1/ln(deg(w)), skipping deg(w)<=1.
query IIR
select node1, node2, round(adamic_adar,4) from adamic_adar('Student', 'id', 'know', 'src', 'dst') order by node1, node2;
----
0	1	1.6315
0	2	1.6315
0	3	1.8204
0	4	0.7213
1	2	1.6315
1	3	1.8204
1	4	0.7213
2	3	1.8204
2	4	0.7213
3	4	0.0
