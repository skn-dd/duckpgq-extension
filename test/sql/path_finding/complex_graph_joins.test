# name: test/sql/path_finding/complex_graph_joins.test
# description: Complex joins between multiple GRAPH_TABLE outputs
# group: [path_finding]

require duckpgq

statement ok
CREATE TABLE nodes(id BIGINT);

statement ok
CREATE TABLE edges(src BIGINT, dst BIGINT);

statement ok
INSERT INTO nodes VALUES (0), (1), (2), (3), (4);

statement ok
INSERT INTO edges VALUES (0, 1), (0, 2), (0, 3), (1, 3), (2, 3), (3, 4);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (
    nodes LABEL N
)
EDGE TABLES (
    edges SOURCE KEY (src) REFERENCES nodes (id)
          DESTINATION KEY (dst) REFERENCES nodes (id)
          LABEL E
);

query I
-SELECT count(*) AS join_count
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
    COLUMNS (b.id AS b_id)
) reached
JOIN GRAPH_TABLE (pg
    MATCH (x:N)-[e:E]->(y:N)
    COLUMNS (x.id AS x_id, y.id AS y_id)
) hop1 ON reached.b_id = hop1.x_id
JOIN GRAPH_TABLE (pg
    MATCH (x:N)-[e:E]->(y:N)
    COLUMNS (x.id AS x_id, y.id AS y_id)
) hop2 ON hop1.y_id = hop2.x_id;
----
2

query I
-SELECT count(*) AS join_count
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
    COLUMNS (b.id AS b_id)
) first_reach
JOIN GRAPH_TABLE (pg
    MATCH (x:N)-[e:E]->{1,2}(y:N)
    COLUMNS (x.id AS x_id, y.id AS y_id)
) second_reach ON first_reach.b_id = second_reach.x_id;
----
5

query I
-SELECT count(*) AS join_count
FROM GRAPH_TABLE (pg
    MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
    COLUMNS (b.id AS b_id)
) reached
JOIN GRAPH_TABLE (pg
    MATCH (x:N)-[e:E]->(y:N)
    COLUMNS (x.id AS x_id, y.id AS y_id)
) incoming ON reached.b_id = incoming.y_id;
----
6

query I
-WITH seeded AS (
    FROM GRAPH_TABLE (pg
        MATCH (a:N WHERE a.id = 0)-[e:E]->{1,3}(b:N)
        COLUMNS (b.id AS b_id)
    )
),
direct AS (
    FROM GRAPH_TABLE (pg
        MATCH (x:N)-[e:E]->(y:N)
        COLUMNS (x.id AS x_id, y.id AS y_id)
    )
)
SELECT count(*) AS join_count
FROM seeded
JOIN direct d1 ON seeded.b_id = d1.x_id
JOIN direct d2 ON d1.y_id = d2.x_id;
----
2

query I
-SELECT count(*) AS cycle_count
FROM GRAPH_TABLE (pg
    MATCH (a:N)-[e:E]->(b:N)
    COLUMNS (a.id AS src_id, b.id AS dst_id)
) e1
JOIN GRAPH_TABLE (pg
    MATCH (a:N)-[e:E]->(b:N)
    COLUMNS (a.id AS src_id, b.id AS dst_id)
) e2 ON e1.dst_id = e2.src_id
JOIN GRAPH_TABLE (pg
    MATCH (a:N)-[e:E]->(b:N)
    COLUMNS (a.id AS src_id, b.id AS dst_id)
) e3 ON e2.dst_id = e3.src_id AND e3.dst_id = e1.src_id;
----
0
